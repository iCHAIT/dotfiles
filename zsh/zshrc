export PATH="/opt/homebrew/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

eval "$(starship init zsh)"
eval "$(zoxide init --cmd z zsh)"
export ANDROID_HOME=$HOME/android-sdk
export PATH=$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools:$PATH

# eza aliases
alias ls='eza --icons --group-directories-first' # 'ls' with icons and better grouping
alias ll='eza -lh --icons --grid'                # 'ls -l' with icons and grid view

# bat aliases
alias cat='bat --paging=never --plain'           # 'cat' via bat, no pager/decorations (real-cat-like)

# Git aliases
alias gs='git status'
alias ga='git add'
alias gaa='git add .'
alias gc='git commit'
alias gca='git commit --amend'
alias gp='git push'
alias gpf='git push --force'
alias gpl='git pull'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gb='git branch'
alias gbd='git branch -d'
alias gl='git log --oneline --graph --decorate'
alias gdf='git diff'
alias gds='git diff --staged'
alias gst='git stash'
alias gstp='git stash pop'

# Claude Code
alias cc='claude'
